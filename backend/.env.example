# =====================================================
# BI Ventas - Variables de entorno (EJEMPLO)
# Copiar como .env y completar con valores reales
# =====================================================

# --- Snowflake Conexión ---
SNOWFLAKE_USER=tu_usuario
SNOWFLAKE_PASSWORD=tu_contraseña
SNOWFLAKE_ACCOUNT=xxxxxxx.region.azure        # ej: vca87843.east-us-2.azure
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MI_BASE_DE_DATOS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_TABLE=WH_POWERBI

# --- Mapeo de columnas ---
# Ajustar según los nombres reales de columnas en tu tabla
COL_DATE=FECHA
COL_AMOUNT=MONTO
COL_REGION=REGION
COL_CHANNEL=CANAL
COL_CATEGORY=CATEGORIA
COL_PRODUCT=PRODUCTO
COL_CUSTOMER=CLIENTE
COL_QUANTITY=CANTIDAD
COL_TRANSACTION_ID=ID_TRANSACCION

# --- Cache y Scheduler ---
CACHE_TTL_HOURS=6         # Horas que dura el caché en memoria
REFRESH_HOUR=3            # Hora del refresh automático (formato 24h)
REFRESH_MINUTE=0

# --- App ---
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
